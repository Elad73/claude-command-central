{
  "name": "claude-command-central",
  "version": "0.1.0",
  "description": "Terminal-native mission control dashboard for agentic workflows.",
  "type": "module",
  "bin": {
    "ccc": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:server && npm run copy:web",
    "build:server": "tsup",
    "build:web": "cd web && npm run build",
    "copy:web": "rm -rf dist/web && cp -r web/dist dist/web",
    "dev:server": "tsup --watch",
    "dev:web": "cd web && npm run dev",
    "start": "node dist/bin.js",
    "ccc": "tsx src/bin.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "terminal",
    "tui",
    "ink",
    "claude-code",
    "agent",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
